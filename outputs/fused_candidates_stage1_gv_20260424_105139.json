      "title": "Training Verifiers to Solve Math Word Problems",
      "title_normalized": "trainingverifierstosolvemathwordproblems",
      "authors": [
        "Karl Cobbe",
        "Vineet Kosaraju",
        "Mohammad Bavarian",
